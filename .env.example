# ==========================================
# Quizanak Frontend Environment Variables (Netlify)
# ==========================================
REACT_APP_BACKEND_URL=https://quizanak-backend.onrender.com

# ==========================================
# Quizanak Backend Environment Variables (Render)
# ==========================================
PORT=5000
MONGODB_URI=mongodb+srv://user:password@imgupload.l8bfttd.mongodb.net/?retryWrites=true&w=majority&appName=imgupload

# Redis Credentials & Configuration
# Render / Upstash / Redis Cloud Connection URL:
REDIS_URL=redis://default:your_redis_password@your_redis_host:6379
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password

# Nodemailer / Google Email Configuration
EMAIL_USER=kuisanak.id@gmail.com

# OPTION 1: Gmail App Password (RECOMMENDED)
# Generate a 16-character App Password at: https://myaccount.google.com/apppasswords
EMAIL_PASS=your_16_character_app_password

# OPTION 2: Google OAuth2 Credentials (Alternative)
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REFRESH_TOKEN=your_google_refresh_token
